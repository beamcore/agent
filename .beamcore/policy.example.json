{
  "version": 1,
  "deny_paths": [
    ".env",
    ".env.*",
    "secrets/**",
    "private/**",
    "_build/**",
    "deps/**",
    ".git/**"
  ],
  "read_only_paths": [
    "mix.lock",
    "config/prod.exs"
  ],
  "allow_write_paths": [
    "lib/**",
    "test/**",
    "README.md",
    "generated/**"
  ],
  "tool_permissions": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "tree": "allow",
    "write": "allow",
    "edit": "allow",
    "patch": "allow",
    "fs": "allow",
    "git": "allow",
    "mix": "allow",
    "image_generation": "allow",
    "task": "deny",
    "web_get": "deny"
  }
}
