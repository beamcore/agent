[
  {
    "id": "replace_exact_block",
    "file": "validation/examples/hello.ex",
    "description": "Replaces an exact multi-line Elixir function block",
    "params": {
      "operation": "replace_exact",
      "old": "  def greet(name) do\n    IO.puts(\"Hello, \" <> name <> \"!\")\n  end",
      "new": "  def greet(name, prefix \\\\ \"Hello\") do\n    IO.puts(prefix <> \", \" <> name <> \"!\")\n  end"
    },
    "expected_success": true,
    "contains": "def greet(name, prefix \\\\ \"Hello\")"
  },
  {
    "id": "replace_exact_explicit_occurrence",
    "file": "validation/examples/hello.ex",
    "description": "Replaces an explicit duplicate occurrence",
    "params": {
      "operation": "replace_exact",
      "old": "  end",
      "new": "  # explicit occurrence\n  end",
      "occurrence": 2
    },
    "expected_success": true,
    "contains": "# explicit occurrence"
  },
  {
    "id": "insert_after_anchor",
    "file": "validation/examples/hello.js",
    "description": "Inserts text after an exact JavaScript anchor",
    "params": {
      "operation": "insert_after",
      "anchor": "  console.log('Hello, ' + name + '!');\n",
      "content": "  return name;\n"
    },
    "expected_success": true,
    "contains": "return name;"
  },
  {
    "id": "replace_range",
    "file": "validation/examples/hello.py",
    "description": "Replaces a fixed inclusive line range",
    "params": {
      "operation": "replace_range",
      "start_line": 5,
      "end_line": 6,
      "content": "def sum_two_numbers(a, b):\n    return a + b + 1"
    },
    "expected_success": true,
    "contains": "return a + b + 1"
  },
  {
    "id": "no_match_failure",
    "file": "validation/examples/hello.ex",
    "description": "Fails when exact text is not found",
    "params": {
      "operation": "replace_exact",
      "old": "def non_existent_function() do\n  :error\nend",
      "new": "def non_existent_function() do\n  :ok\nend"
    },
    "expected_success": false
  },
  {
    "id": "ambiguous_match_failure",
    "file": "validation/examples/hello.ex",
    "description": "Fails when occurrence is ambiguous",
    "params": {
      "operation": "replace_exact",
      "old": "  end",
      "new": "# ending"
    },
    "expected_success": false
  }
]
